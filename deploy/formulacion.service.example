[Unit]
Description=Gunicorn para Formulacion Libertad
After=network.target

[Service]
User=TU_USUARIO
Group=www-data
WorkingDirectory=/home/TU_USUARIO/apps/formulacion_libertad
EnvironmentFile=/home/TU_USUARIO/apps/formulacion_libertad/.env
Environment=PATH=/home/TU_USUARIO/apps/formulacion_libertad/venv/bin
ExecStart=/home/TU_USUARIO/apps/formulacion_libertad/venv/bin/gunicorn config.wsgi:application --workers 3 --bind 127.0.0.1:8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
